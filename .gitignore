# Ignorar todo por defecto
*

# Mantener el propio .gitignore
!.gitignore

# Archivos en la raíz del repo
!README.md
!setup.sh

# home/ -> dotfiles del $HOME
!home/
!home/**

# backup-noctalia (excluyendo cache)
!backup-noctalia/
!backup-noctalia/config/
!backup-noctalia/config/**
backup-noctalia/cache/
backup-noctalia/cache/**

# Configs existentes
!hypr/
!hypr/**

!kitty/
!kitty/**

!nvim/
!nvim/**

!rofi/
!rofi/**

!waybar/
!waybar/**

# Nuevas configs
!btop/
!btop/**

!cava/
!cava/**

!gtk-3.0/
!gtk-3.0/**

!yazi/
!yazi/**

!fontconfig/
!fontconfig/**

# Archivos sueltos
!mimeapps.list
!user-dirs.dirs
!user-dirs.locale
