# Ignorar todo por defecto
*

# Mantener el propio .gitignore
!.gitignore

# Archivos en la raíz del repo
!README.md
!setup.sh

# home/ -> dotfiles del $HOME
!home/
!home/**

# Configs existentes
!hypr/
!hypr/**

!kitty/
!kitty/**

!nvim/
!nvim/**

!rofi/
!rofi/**

!waybar/
!waybar/**

# Nuevas configs
!btop/
!btop/**

!cava/
!cava/**

!gtk-3.0/
!gtk-3.0/**

!yazi/
!yazi/**

!fontconfig/
!fontconfig/**

# swaync -> notificaciones
!swaync/
!swaync/**

# waypaper -> GUI de fondos
!waypaper/
!waypaper/**

# systemd -> servicios de usuario
!systemd/
!systemd/**

# Archivos sueltos
!mimeapps.list
!user-dirs.dirs
!user-dirs.locale
